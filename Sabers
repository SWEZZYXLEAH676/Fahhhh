local staminaEnabled = false

local function getStaminaValue()
    local playerGui = localPlayer:FindFirstChild("PlayerGui")
    if playerGui then
        local staminaFrame = playerGui:FindFirstChild("StaminaFrame") or playerGui:FindFirstChild("StaminaBar")
        if staminaFrame then
            local value = staminaFrame:FindFirstChild("Value") or staminaFrame:FindFirstChild("Stamina")
            if value then return value end
        end
    end
    for _, child in ipairs(localPlayer:GetDescendants()) do
        if child:IsA("NumberValue") and (child.Name:lower():find("stamina") or child.Name:lower():find("energy")) then
            return child
        end
    end
    return nil
end

mainTab:CreateToggle({
    Name = "infinite fuel (aka inf stamina)",
    CurrentValue = false,
    Flag = "stamina",
    Callback = function(state)
        staminaEnabled = state
        if not state then 
            return 
        end
        task.spawn(function()
            local staminaValue = getStaminaValue()
            if not staminaValue then
                warn("Could not find stamina value – infinite stamina may not work")
                return
            end
            while staminaEnabled do
                staminaValue.Value = 100
                task.wait(0.05)
            end
        end)
    end
})

local killFarmEnabled = false
local killFarmDelay = 1.0
local killFarmRunning = false

local function attackTarget(targetChar)
    if not targetChar or not targetChar.Parent then return end
    fireRemote("MouseDown")
    fireRemote("Attack", math.random(1,10), 1, false, false)
    fireRemote("MouseUp")
    fireRemote("Swing")
    fireRemote("OnHit", targetChar)
    fireRemote("FinishSwingNoBounce")
    fireRemote("ResetSwingDirection")
    task.wait(0.1)
end

local function teleportToCharacter(targetChar)
    local localChar = localPlayer.Character
    local localHrp = localChar and localChar:FindFirstChild("HumanoidRootPart")
    local targetHrp = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
    if not localHrp or not targetHrp then return false end
    localHrp.CFrame = CFrame.new(targetHrp.Position + Vector3.new(0, 3, 0))
    task.wait(0.05)
    return true
end

local function killFarmLoop()
    while killFarmEnabled and killFarmRunning do
        local playersList = players:GetPlayers()
        local anyAttacked = false
        for _, plr in ipairs(playersList) do
            if not killFarmEnabled then break end
            if plr ~= localPlayer then
                local targetChar = plr.Character
                if targetChar then
                    local hum = targetChar:FindFirstChildWhichIsA("Humanoid")
                    if hum and hum.Health > 0 then
                        if teleportToCharacter(targetChar) then
                            task.wait(0.1)
                            attackTarget(targetChar)
                            anyAttacked = true
                            for i = 1, math.floor(killFarmDelay * 10) do
                                if not killFarmEnabled then break end
                                task.wait(0.1)
                            end
                        end
                    end
                end
            end
        end
        if not anyAttacked and killFarmEnabled then task.wait(0.5) end
    end
end

mainTab:CreateToggle({
    Name = "Auto Goto All (Kill Farm)",
