local loopGotoEnabled = false
local loopGotoTargetName = ""
local loopGotoInterval = 1.0
local loopGotoRunning = false

local function teleportToDisplayName(displayName)
    local targetPlayer = nil
    for _, plr in ipairs(players:GetPlayers()) do
        if plr.DisplayName == displayName then
            targetPlayer = plr
            break
        end
    end
    if not targetPlayer then return false end
    local targetChar = targetPlayer.Character
    if not targetChar then return false end
    local targetHrp = targetChar:FindFirstChild("HumanoidRootPart")
    if not targetHrp then return false end
    local localChar = localPlayer.Character
    local localHrp = localChar and localChar:FindFirstChild("HumanoidRootPart")
    if not localHrp then return false end
    localHrp.CFrame = CFrame.new(targetHrp.Position + Vector3.new(0, 3, 0))
    return true
end

local function loopGotoPlayer()
    while loopGotoEnabled and loopGotoRunning do
        if loopGotoTargetName and loopGotoTargetName ~= "" then
            local success = teleportToDisplayName(loopGotoTargetName)
            if not success then
                task.wait(loopGotoInterval)
            else
                task.wait(loopGotoInterval)
            end
        else
            task.wait(loopGotoInterval)
        end
    end
end

